generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  apps      App[]
  users     User[]
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String?
  organizationId String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Template {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  category       String
  complexity     String
  schemaDefaults Json
  createdAt      DateTime @default(now())
  apps           App[]
}

model App {
  id             String          @id @default(cuid())
  name           String
  organizationId String?
  templateId     String
  createdAt      DateTime        @default(now())
  organization   Organization?   @relation(fields: [organizationId], references: [id])
  template       Template        @relation(fields: [templateId], references: [id])
  mutations      Mutation[]
  previews       Preview[]
  schemas        RuntimeSchema[]
}

model RuntimeSchema {
  id        String          @id @default(cuid())
  appId     String
  version   Int
  schema    Json
  createdAt DateTime        @default(now())
  app       App             @relation(fields: [appId], references: [id])
  versions  SchemaVersion[]

  @@unique([appId, version])
}

model SchemaVersion {
  id              String        @id @default(cuid())
  runtimeSchemaId String
  version         Int
  snapshot        Json
  createdAt       DateTime      @default(now())
  runtimeSchema   RuntimeSchema @relation(fields: [runtimeSchemaId], references: [id])

  @@unique([runtimeSchemaId, version])
}

model Mutation {
  id            String   @id @default(cuid())
  appId         String
  instruction   String
  summary       String?
  schemaVersion Int?
  createdAt     DateTime @default(now())
  app           App      @relation(fields: [appId], references: [id])
}

model Preview {
  id           String    @id @default(cuid())
  appId        String
  token        String    @unique
  frozenSchema Json
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  app          App       @relation(fields: [appId], references: [id])
}
